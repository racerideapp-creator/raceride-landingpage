# Cloudflare Pages custom headers
# Format: URL (or glob) auf einer Zeile, gefolgt von je einer Header-Zeile
# mit vier Leerzeichen davor.
#
# Grund: raceride.app/sitemap.xml lieferte am 2026-07-15 einen Edge-
# cached HTML-Stand statt der echten XML-Sitemap. Der stale Eintrag
# stammte aus einer Zeit, bevor Cloudflare Pages den Default-Header
# public,max-age=0,must-revalidate an alles setzte. Damit das nicht
# nochmal von einem Default-Wechsel abhaengt, hier explizit fuer alle
# Suchmaschinen-relevanten Files: kein Edge-Cache-Eintrag, jeder
# Request revalidiert. Kosten vernachlaessigbar (kleine Dateien,
# 304-Antworten dominieren dank ETag).

/sitemap.xml
    Cache-Control: public, max-age=0, must-revalidate
    Content-Type: application/xml; charset=utf-8

/robots.txt
    Cache-Control: public, max-age=0, must-revalidate
    Content-Type: text/plain; charset=utf-8
